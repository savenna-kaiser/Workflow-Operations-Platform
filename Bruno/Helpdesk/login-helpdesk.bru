meta {
  name: Login (Helpdesk)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "username": "{{helpdesk_user}}",
    "password": "{{helpdesk_pass}}"
  }
}

assert {
  res.status: eq 200
  res.body.ok: eq true
  res.body.user.samAccountName: eq {{helpdesk_user}}
  res.body.user.role: eq helpdesk
}

script:post-response {
  bru.setVar("current_user", res.getBody().user?.samAccountName);
}
