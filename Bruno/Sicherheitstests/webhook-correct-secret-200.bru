meta {
  name: Webhook (Korrektes Secret – 200)
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/api/topdesk/webhook
  body: json
  auth: none
}

headers {
  X-TopDesk-Secret: {{topdesk_webhook_secret}}
}

body:json {
  {
    "changeId": "C2405-123"
  }
}

docs {
  Korrektes Secret aus der Environment-Variable.
  Erwartet: 200 mit queued:true – Change wird async verarbeitet.
  Kein Session-Cookie nötig.
}

assert {
  res.status: eq 200
  res.body.ok: eq true
  res.body.queued: eq true
}
