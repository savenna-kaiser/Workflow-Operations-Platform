meta {
  name: Webhook (Falsches Secret – 401)
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/api/topdesk/webhook
  body: json
  auth: none
}

headers {
  X-TopDesk-Secret: falsches-secret
}

body:json {
  {
    "changeId": "C2405-999"
  }
}

docs {
  Falsches X-TopDesk-Secret.
  Erwartet: 401 – timingSafeEqual schlägt fehl, kein Body in der Response.
}

assert {
  res.status: eq 401
}
