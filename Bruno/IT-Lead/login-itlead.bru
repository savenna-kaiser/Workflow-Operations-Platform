meta {
  name: Login (IT-Lead)
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "username": "{{lead_user}}",
    "password": "{{lead_pass}}"
  }
}

assert {
  res.status: eq 200
  res.body.ok: eq true
  res.body.user.samAccountName: eq {{lead_user}}
  res.body.user.role: eq it-lead
}

script:post-response {
  bru.setVar("current_user", res.getBody().user?.samAccountName);
}
