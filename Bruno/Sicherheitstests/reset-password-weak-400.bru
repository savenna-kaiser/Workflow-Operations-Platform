meta {
  name: Reset Password (Schwaches Passwort – 400)
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/api/users/{{test_sam}}/reset-password
  body: json
  auth: none
}

body:json {
  {
    "newPassword": "kurz",
    "mustChange": true
  }
}

docs {
  Erwartet: 400 – Passwort erfüllt nicht die Komplexitätsanforderungen.
  Testet die Zod-Validierung (min 8 Zeichen, Groß+Klein+Zahl).
}

assert {
  res.status: eq 400
  res.body.error: eq Validierungsfehler
}
