meta {
  name: Reset Password (Helpdesk – 200)
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/api/users/{{test_sam}}/reset-password
  body: json
  auth: none
}

body:json {
  {
    "newPassword": "NeuesPasswort1!",
    "mustChange": true,
    "cannotChange": false
  }
}

docs {
  Voraussetzung: Als Helpdesk eingeloggt.
  Reset-Password ist für Helpdesk erlaubt.
}

assert {
  res.status: eq 200
  res.body.ok: eq true
}
