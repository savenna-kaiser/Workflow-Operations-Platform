meta {
  name: Login (Falsches Passwort)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "username": "{{admin_user}}",
    "password": "{{admin_pass}}"
  }
}

vars:pre-request {
  admin_user: admin.ituser
  admin_pass: Ananas2023!
}

assert {
  res.status: eq 401
  res.body.error: eq Anmeldung fehlgeschlagen.
}
