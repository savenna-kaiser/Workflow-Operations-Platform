meta {
  name: Webhook (Kein Secret – 401)
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/api/topdesk/webhook
  body: json
  auth: none
}

body:json {
  {
    "changeId": "C2405-999"
  }
}

docs {
  Kein X-TopDesk-Secret Header.
  Erwartet: 401 – Webhook ohne Secret wird abgelehnt.
  Kein Session-Cookie nötig – Webhook hat kein RBAC.
}

assert {
  res.status: eq 401
}
