meta {
  name: Edit User (Helpdesk – 403)
  type: http
  seq: 9
}

put {
  url: {{baseUrl}}/api/users/{{test_sam}}/edit
  body: json
  auth: none
}

body:json {
  {
    "Department": "IT"
  }
}

docs {
  Voraussetzung: Als Helpdesk eingeloggt.
  Erwartet: 403 – Helpdesk darf Attribute nicht bearbeiten.
}

assert {
  res.status: eq 403
}
